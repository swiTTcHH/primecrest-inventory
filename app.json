{
  "expo": {
    "name": "PrimeCrest Inventory",
    "slug": "primeCrestMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.png",
    "scheme": "primecrestmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/Logo.png",
      "bundleIdentifier": "com.switch0019.primeCrestMobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Logo.png",
        "backgroundImage": "./assets/images/Logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.switch0019.primeCrestMobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/Logo.png",
            "imageWidth": 100
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6691ff4d-a12f-4632-92dc-85c73363f9e3"
      }
    }
  }
}
